{
  "rewrites": [
    { "source": "/(.*)", "destination": "/" }
  ],
  "headers": [
    {
      "source": "/index.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, no-cache, must-revalidate" }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ],
  "crons": [
    {
      "path": "/api/keepalive-supabase",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/keepalive-supabase",
      "schedule": "0 14 * * *"
    },
    {
      "path": "/api/keepalive-supabase",
      "schedule": "0 22 * * *"
    }
  ]
}
